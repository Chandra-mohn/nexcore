import ./apis/account-api.api
import ./apis/audit-api.api
import ./apis/notification-api.api
import ./rules/account-validation.rules
import ./rules/transfer-validation.rules
import ./transforms/account-transform.xform
import ./transforms/address-normalize.xform
import ./schemas/account.schema

service AccountService
    description "Core account management -- implements full AccountAPI contract"

    implements AccountAPI
    consumes AuditAPI, NotificationAPI

    // ---------------------------------------------------------------
    // Infrastructure Configuration (defaults, overridable via config file)
    // ---------------------------------------------------------------

    config
        // Observability
        logging_correlation_header "X-Request-ID"
        tracing_provider "opentelemetry"
        tracing_service_name "account-service"
        metrics_provider "prometheus"
        metrics_namespace "account"

        // Database
        account_db_pool_size 10
        account_db_timeout 5

        // Service call defaults
        audit_call_timeout 3
        notification_call_timeout 3
    end

    // ---------------------------------------------------------------
    // Handlers
    // ---------------------------------------------------------------

    handler listAccounts
        authorize scope "accounts:read"
        lookup accounts from AccountDB
            where status = request.status
            where region = request.region
            where created_at >= request.since
        end
        transform accounts using FormatAccountSummary.xform into response
    end

    handler getAccount
        authorize scope "accounts:read"
        lookup account from AccountDB
            where account_id = request.account_id
        end
        on_error
            404 when account is null
        end
        transform account using FormatAccountDetail.xform into response
    end

    handler getBalance
        authorize scope "accounts:balance"
        lookup account from AccountDB
            where account_id = request.account_id
        end
        on_error
            404 when account is null
        end
        transform account using FormatBalance.xform into response
    end

    handler createAccount
        authorize scope "accounts:write"
        validate request using AccountValidation.rules
        transform request using NormalizeAccount.xform into normalized
        persist normalized to AccountDB
        call AuditAPI.logChange with action "account.created"
        publish AccountCreated
        respond 201
    end

    handler updateAddress
        authorize scope "accounts:write"
        validate request using AddressValidation.rules
        transform request using AddressNormalize.xform into normalized
        lookup account from AccountDB
            where account_id = request.account_id
        end
        on_error
            404 when account is null
        end
        persist normalized to AccountDB
        call AuditAPI.logChange with action "address.updated"
        publish AddressChanged
        respond 200
    end

    handler closeAccount
        authorize scope "accounts:admin"
        lookup account from AccountDB
            where account_id = request.account_id
        end
        on_error
            404 when account is null
            409 when account.balance != 0
        end
        transaction
            persist account.status = "closed" to AccountDB
            call AuditAPI.logChange with action "account.closed"
            publish AccountClosed
        on_rollback
            call AuditAPI.logChange with action "account.close.failed"
        end
    end

    handler transferFunds
        authorize scope "accounts:transfer"
        validate request using TransferValidation.rules
        transaction
            lookup source from AccountDB
                where account_id = request.source_account_id
            end
            lookup target from AccountDB
                where account_id = request.target_account_id
            end
            on_error
                404 when source is null
                404 when target is null
                422 when source.balance < request.amount
            end
            transform source, target, request using ApplyTransfer.xform into balances
            persist balances.source to AccountDB
            persist balances.target to AccountDB
            publish BalanceChanged
            call AuditAPI.logChange with action "transfer.completed"
        on_rollback
            call AuditAPI.logChange with action "transfer.failed"
        end
        call NotificationAPI.sendEmail with template "transfer_confirmation"
        respond 202
    end

    // ---------------------------------------------------------------
    // Cache Strategy
    // ---------------------------------------------------------------

    cache
        getAccount ttl 30 seconds invalidate_on updateAddress, closeAccount
        getBalance ttl 15 seconds invalidate_on transferFunds, closeAccount
        listAccounts ttl 60 seconds invalidate_on createAccount, closeAccount
    end

    // ---------------------------------------------------------------
    // Health Checks
    // ---------------------------------------------------------------

    health "/health"
        check database AccountDB timeout cfg.account_db_timeout seconds
        check service AuditAPI timeout cfg.audit_call_timeout seconds
        check service NotificationAPI timeout cfg.notification_call_timeout seconds
    end

    ready "/ready"
end
